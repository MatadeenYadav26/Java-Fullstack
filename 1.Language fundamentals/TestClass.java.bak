class Student 
{
	// they are assigned default values
	int age;
	String name;
	String course;
	
	
	void study(){
	// jo variable inside method hoga usko bolege local variable, lekin unko memory me koi default memory nahi milti.
	// They are not assinged any default values.
				System.out.println("Student is Studying!");
	}
}


public class  TestClass
{
	public static void main(String[] args){
	Student s = new Student(); // object creation , s is not a primitive type itsa refrence type.ye "." kouse arke refrence address dega and waha par se value extract hogi jo ther classs me stored hai.
	System.out.println(s.age);	
	System.out.println(s.name);
	
	// the default values now can be updated and printed.
	s.age=20;
	s.name="Aman";
	System.out.println(s.age1);
	System.out.println(s.name1);
	
	}
}